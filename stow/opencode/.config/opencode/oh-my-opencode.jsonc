{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "background_task": {
    "defaultConcurrency": 1,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "anthropic": 1,
      "openai": 1,
      "google": 1
    }
  },

  // 2) Per-agent tuning
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "reasoningEffort": "medium",
      "temperature": 0.2
    },

    "hephaestus": {
      "model": "openai/gpt-5.4-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low",
      "temperature": 0.1,
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.2-codex",
        "openai/gpt-5-codex"
      ],
      "prompt_append": "Keep edits minimal and file-scoped."
    },

    "prometheus": {
      "model": "openai/gpt-5.4-mini",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "ask"
      },
      "prompt_append": "You are a planning/review agent. Do not modify files directly."
    },

    "metis": {
      "model": "openai/gpt-5.1-codex",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },

    "explore": {
      "model": "opencode/gpt-5-nano",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },

    "oracle": {
      "model": "openai/gpt-5.2",
      "temperature": 0.1,
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.1-codex-max"
      ]
    },

    "librarian": {
      "model": "openai/gpt-5.4-mini-fast",
      "temperature": 0.1,
      "fallback_models": [
        "openai/gpt-5.3-codex-spark",
        "openai/gpt-5.3-codex"
      ]
    }
  },

  // 3) Category defaults for delegated task routing
  "categories": {
    "deep": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "openai/gpt-5.4-fast",
        "openai/gpt-5.2"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.1-codex-max",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.2-codex"
      ]
    },
    "artistry": {
      "model": "openai/gpt-5.3-codex",
      "fallback_models": [
        "openai/gpt-5.1-codex",
        "openai/gpt-5-codex"
      ]
    },
    "writing": {
      "model": "openai/gpt-5.2",
      "fallback_models": [
        "openai/gpt-5.4-mini"
      ]
    },
    "quick": {
      "model": "opencode/gpt-5-nano",
      "fallback_models": [
        "openai/gpt-5.1-codex-mini",
        "openai/gpt-5.4-mini-fast"
      ]
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini-fast",
      "fallback_models": [
        "openai/gpt-5.1-codex-mini",
        "openai/gpt-5.3-codex-spark"
      ]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.2-codex",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4"
      ]
    }
  }
}
